# Shared PostgreSQL — EasyPanel-hosted or Neon. Same URL for every terminal (single source of truth).
DATABASE_URL="postgres://posclaude:posclaude@45.55.79.97:5430/posclaude?sslmode=disable"

# REQUIRED in production — the server refuses to start without this set
# (falls back to an insecure dev-only default only when NODE_ENV != production).
JWT_SECRET="2a73a2c5406a274604734d1a47a4519ed537fe91fad50d216684ad2ac9d98fd2"

# REQUIRED in production — comma-separated list of origins allowed to call this
# API, e.g. "https://pos.mystore.com,https://admin.mystore.com". The server
# refuses to start in production without this set, to avoid accidentally
# running with an open (allow-all) CORS policy.
CORS_ORIGIN="http://localhost:5173"

NODE_ENV=development
PORT=4000
