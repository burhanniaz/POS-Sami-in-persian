// POS System — Prisma schema
// DB: shared PostgreSQL (EasyPanel-hosted or Neon) — single source of truth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / Terminals ----------

model Terminal {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Register 1"
  createdAt DateTime @default(now())

  sessions  CashierSession[]
  sales     Sale[]
  returns   Return[]
  auditLogs AuditLog[]
}

model Cashier {
  id        String   @id @default(cuid())
  name      String
  pinHash   String // bcrypt hash of 4-6 digit PIN
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions  CashierSession[]
  sales     Sale[]
  returns   Return[]
  auditLogs AuditLog[]
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  approvedSales Sale[]    @relation("DiscountApprover")
  auditLogs     AuditLog[]
}

// One row per login/logout at a terminal — used for "which terminal + which cashier" audit trail
model CashierSession {
  id         String    @id @default(cuid())
  terminal   Terminal  @relation(fields: [terminalId], references: [id])
  terminalId String
  cashier    Cashier   @relation(fields: [cashierId], references: [id])
  cashierId  String
  startedAt  DateTime  @default(now())
  endedAt    DateTime? // null while active; set on logout or auto-lock timeout
}

// ---------- Catalog ----------

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id                 String   @id @default(cuid())
  name               String // Persian name
  barcode            String   @unique
  barcodeGenerated   Boolean  @default(false) // true if system auto-generated (no vendor barcode)
  imageUrl           String?  // path under /uploads, served statically by the backend
  category           String?
  costPrice          Decimal  @db.Decimal(12, 2)
  salePrice          Decimal  @db.Decimal(12, 2)
  stockQty           Decimal  @default(0) @db.Decimal(12, 3)
  unit               String   @default("piece") // piece | box | kg
  lowStockThreshold  Decimal  @default(5) @db.Decimal(12, 3)
  supplier           Supplier? @relation(fields: [supplierId], references: [id])
  supplierId         String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  saleItems   SaleItem[]
}

// ---------- Customers / Loans ----------

model Customer {
  id           String   @id @default(cuid())
  name         String
  cnic         String?  // national ID card number
  address      String?
  phone        String?
  creditLimit  Decimal  @default(0) @db.Decimal(12, 2)
  loanBalance  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  sales   Sale[]
}

// ---------- Sales / Checkout ----------

enum PaymentMethod {
  CASH
  LOAN
  PARTIAL // cash + loan combined
}

enum SaleStatus {
  COMPLETED
  VOID
}

model Sale {
  id              String        @id @default(cuid())
  terminal        Terminal      @relation(fields: [terminalId], references: [id])
  terminalId      String
  cashier         Cashier       @relation(fields: [cashierId], references: [id])
  cashierId       String
  customer        Customer?     @relation(fields: [customerId], references: [id])
  customerId      String?

  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  total           Decimal       @db.Decimal(12, 2)

  paymentMethod   PaymentMethod
  cashPaid        Decimal       @default(0) @db.Decimal(12, 2)
  loanPaid        Decimal       @default(0) @db.Decimal(12, 2) // portion charged to customer loan

  status          SaleStatus    @default(COMPLETED)

  // Discount authorization: set when discount exceeded the configured threshold
  approvedBy      Admin?        @relation("DiscountApprover", fields: [approvedById], references: [id])
  approvedById    String?

  createdAt       DateTime      @default(now())

  items   SaleItem[]
  returns Return[]
}

model SaleItem {
  id             String   @id @default(cuid())
  sale           Sale     @relation(fields: [saleId], references: [id])
  saleId         String
  product        Product  @relation(fields: [productId], references: [id])
  productId      String
  qty            Decimal  @db.Decimal(12, 3)
  unitPrice      Decimal  @db.Decimal(12, 2) // price at time of sale
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @db.Decimal(12, 2)

  returnItems ReturnItem[]
}

// ---------- Returns / Refunds ----------

model Return {
  id         String   @id @default(cuid())
  sale       Sale     @relation(fields: [saleId], references: [id])
  saleId     String
  terminal   Terminal @relation(fields: [terminalId], references: [id])
  terminalId String
  cashier    Cashier  @relation(fields: [cashierId], references: [id])
  cashierId  String
  reason     String?
  createdAt  DateTime @default(now())

  items ReturnItem[]
}

model ReturnItem {
  id           String   @id @default(cuid())
  return       Return   @relation(fields: [returnId], references: [id])
  returnId     String
  saleItem     SaleItem @relation(fields: [saleItemId], references: [id])
  saleItemId   String
  qty          Decimal  @db.Decimal(12, 3)
  refundAmount Decimal  @db.Decimal(12, 2)
  restocked    Boolean  @default(true) // false if marked damaged
}

// ---------- Audit ----------

model AuditLog {
  id         String    @id @default(cuid())
  terminal   Terminal? @relation(fields: [terminalId], references: [id])
  terminalId String?
  cashier    Cashier?  @relation(fields: [cashierId], references: [id])
  cashierId  String?
  admin      Admin?    @relation(fields: [adminId], references: [id])
  adminId    String?
  action     String // e.g. "sale.create", "product.update", "auth.login"
  details    Json?
  createdAt  DateTime  @default(now())
}

// ---------- Settings ----------

model AppSetting {
  key   String @id
  value String
}
